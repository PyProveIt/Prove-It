\left(\varepsilon \mapsto \left\{P_{\rm fail}(\varepsilon) \leq \left(\frac{1}{4} \cdot \left(\left(\sum_{l=-2^{t - 1} + 1}^{-\left(\varepsilon + 1\right)} \frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}}\right) + \left(\sum_{l=\varepsilon + 1}^{2^{t - 1}} \frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}}\right)\right)\right) \textrm{ if } \varepsilon \in \{1~\ldotp \ldotp~2^{t - 1} - 2\}\right..\right)
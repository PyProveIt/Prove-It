\left(\sum_{k=0}^{2^{t^{*}} - 1} \left(\mathsf{e}^{2 \cdot \pi \cdot i \cdot \varphi \cdot k} \cdot \lvert k \rangle\right), \left(\sum_{k=0}^{2^{t^{\prime}} - 1} \left(\mathsf{e}^{2 \cdot \pi \cdot i \cdot \varphi \cdot k} \cdot \lvert k \rangle\right)\right) + \left(\sum_{k=\left(2^{t^{\prime}} - 1\right) + 1}^{2^{t^{*}} - 1} \left(\mathsf{e}^{2 \cdot \pi \cdot i \cdot \varphi \cdot k} \cdot \lvert k \rangle\right)\right)\right)
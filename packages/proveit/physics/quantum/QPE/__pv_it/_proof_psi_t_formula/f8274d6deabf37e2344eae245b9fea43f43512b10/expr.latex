\left(\left(2^{t^{\prime}} - 1\right) < \left(2^{t^{*}} - 1\right), t^{\prime} \in \mathbb{N}, t^{*} = \left(t^{\prime} + 1\right), \psi_{t^{\prime}} = \left(\frac{1}{2^{\frac{t^{\prime}}{2}}} \cdot \left(\sum_{k=0}^{2^{t^{\prime}} - 1} \left(\mathsf{e}^{2 \cdot \pi \cdot i \cdot \varphi \cdot k} \cdot \lvert k \rangle\right)\right)\right), \psi_{t^{*}} \neq \left(\frac{1}{2^{\frac{t^{*}}{2}}} \cdot \left(\sum_{k=0}^{2^{t^{*}} - 1} \left(\mathsf{e}^{2 \cdot \pi \cdot i \cdot \varphi \cdot k} \cdot \lvert k \rangle\right)\right)\right)\right)
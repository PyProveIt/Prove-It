\left\{ \begin{array}{l}
{\rm lambda}: \left[{_{-}a} \mapsto \left(\left(\sum_{k=0}^{2^{t^{*}} - 1} \left(\mathsf{e}^{2 \cdot \pi \cdot i \cdot \varphi \cdot k} \cdot \lvert k \rangle\right)\right) = \left(\left(\sum_{k=0}^{2^{t^{\prime}} - 1} \left(\mathsf{e}^{2 \cdot \pi \cdot i \cdot \varphi \cdot k} \cdot \lvert k \rangle\right)\right) + \left(\sum_{k={_{-}a}}^{2^{t^{*}} - 1} \left(\mathsf{e}^{2 \cdot \pi \cdot i \cdot \varphi \cdot k} \cdot \lvert k \rangle\right)\right)\right)\right)\right]\\
{_{-}a}: \left(\left(2^{t^{\prime}} - 1\right) + 1\right)\\
\end{array} \right\}

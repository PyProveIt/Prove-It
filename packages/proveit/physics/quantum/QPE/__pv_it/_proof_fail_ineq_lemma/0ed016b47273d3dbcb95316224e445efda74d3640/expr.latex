\left(a_{1} \mapsto \left\{\left(a_{1} \cdot \left(\sum_{l=\varepsilon + 1}^{2^{t - 1}} \frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}}\right)\right) = \left(\sum_{l=\varepsilon + 1}^{2^{t - 1}} \left(a_{1} \cdot \frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}}\right)\right) \textrm{ if } a_{1} \in \mathbb{C}\right..\right)
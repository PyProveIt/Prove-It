\left[\forall_{l \in \{-2^{t - 1} + 1~\ldotp \ldotp~-\left(\varepsilon + 1\right)\}}~\left(\frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}} \in \mathbb{C}\right)\right] \Rightarrow \left[\forall_{a_{1} \in \mathbb{C}}~\left(\left(a_{1} \cdot \left(\sum_{l=-2^{t - 1} + 1}^{-\left(\varepsilon + 1\right)} \frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}}\right)\right) = \left(\sum_{l=-2^{t - 1} + 1}^{-\left(\varepsilon + 1\right)} \left(a_{1} \cdot \frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}}\right)\right)\right)\right]
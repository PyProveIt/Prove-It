\left(\forall_{l \in \{\varepsilon + 1~\ldotp \ldotp~2^{t - 1}\}}~\left(\frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}} \in \mathbb{C}\right), \forall_{a_{1} \in \mathbb{C}}~\left(\left(a_{1} \cdot \left(\sum_{l=\varepsilon + 1}^{2^{t - 1}} \frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}}\right)\right) = \left(\sum_{l=\varepsilon + 1}^{2^{t - 1}} \left(a_{1} \cdot \frac{1}{\left(l - \left(2^{t} \cdot \delta\right)\right)^{2}}\right)\right)\right)\right)
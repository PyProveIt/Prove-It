\left\{\forall_{a, b \in \mathbb{C}^{2}}~\left[\forall_{x, y \in \left(\mathbb{C}^{2}\right)^{\otimes n}}~\left(\hspace{2em} \Qcircuit@C=1em @R=.7em{
& \lstick{a} & \gate{u} & \control \qw \qwx[1] & \rstick{b} \qw   \\ 

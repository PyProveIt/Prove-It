\left(\left(i, j, k\right) \mapsto \left\{\forall_{x_{1}, \ldots, x_{i}, y_{1}, \ldots, y_{j}, z_{1}, \ldots, z_{k}}~\left(\left(x_{1} {\otimes} \ldots {\otimes} x_{i} {\otimes} \left(y_{1} + \ldots + y_{j}\right) {\otimes} z_{1} {\otimes} \ldots {\otimes} z_{k}\right) = \left(\left(x_{1} {\otimes} \ldots {\otimes} x_{i} {\otimes} y_{1} {\otimes} z_{1} {\otimes} \ldots {\otimes} z_{k}\right) + \ldots + \left(x_{1} {\otimes} \ldots {\otimes} x_{i} {\otimes} y_{j} {\otimes} z_{1} {\otimes} \ldots {\otimes} z_{k}\right)\right)\right) \textrm{ if } i \in \mathbb{N} ,  j \in \mathbb{N} ,  k \in \mathbb{N}\right..\right)
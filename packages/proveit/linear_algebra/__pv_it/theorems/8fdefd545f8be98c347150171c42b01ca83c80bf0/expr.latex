\forall_{\alpha}~\left(\left(x_{1} {\otimes} \ldots {\otimes} x_{m} {\otimes} \left(\alpha \thinspace y\right) {\otimes} z_{1} {\otimes} \ldots {\otimes} z_{n}\right) = \left(\alpha \thinspace \left(x_{1} {\otimes} \ldots {\otimes} x_{m} {\otimes} y {\otimes} z_{1} {\otimes} \ldots {\otimes} z_{n}\right)\right)\right)
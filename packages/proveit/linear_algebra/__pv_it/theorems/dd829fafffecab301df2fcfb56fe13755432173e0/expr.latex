\forall_{m, n \in \mathbb{N}}~\left[\forall_{a_{1}, \ldots, a_{m}, x, y, z_{1}, \ldots, z_{n}}~\left(\left(\left(a_{1} {\otimes} \ldots {\otimes} a_{m} {\otimes} x {\otimes} z_{1} {\otimes} \ldots {\otimes} z_{n}\right) = \left(a_{1} {\otimes} \ldots {\otimes} a_{m} {\otimes} y {\otimes} z_{1} {\otimes} \ldots {\otimes} z_{n}\right)\right) \Leftrightarrow \left(x = y\right)\right)\right]
\left(k \mapsto \left\{\forall_{b \in \mathbb{C}}~\left[\forall_{A, x}~\left(\left(\left(A \thinspace x\right) = \left(b \thinspace x\right)\right) \Rightarrow \left(\left(A^{k} \thinspace x\right) = \left(b^{k} \thinspace x\right)\right)\right)\right] \textrm{ if } k \in \mathbb{N}^+\right..\right)